# ── Idea Factory v4.0 — API Keys ──────────────────────
# Copy this file to .env and fill in your keys.
# At minimum you need ANTHROPIC_API_KEY (Claude).
# The more keys you add, the more powerful the analysis.

# REQUIRED — Claude (deep analysis + scoring)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# RECOMMENDED — OpenAI GPT-4o (business model & revenue)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# RECOMMENDED — Grok (X/Twitter sentiment scanning)
# Get yours at: https://console.x.ai/
GROK_API_KEY=

# OPTIONAL — Perplexity (web research & competitors)
# Get yours at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── Other Settings (defaults work fine) ───────────────
STRIPE_SECRET_KEY=sk_test_placeholder
